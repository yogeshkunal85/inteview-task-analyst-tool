# Local Postgres (default for development)
# Create the database first, e.g.: createdb monetizely
DATABASE_URL="postgres://postgres:postgres@localhost:5432/monetizely"

# If your local user has no password (common on macOS Homebrew):
# DATABASE_URL="postgres://YOUR_USERNAME@localhost:5432/monetizely"

# Hosted Postgres (Neon, Vercel Postgres, etc.):
# DATABASE_URL="postgres://USER:PASSWORD@HOST:5432/DB?sslmode=require"
